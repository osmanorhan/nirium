{
    "layer": "top",
    "position": "top",
    "height": 34,
    "margin-top": 6,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 0,
    "spacing": 4,
    "modules-left": [
        "niri/workspaces",
        "niri/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "cpu",
        "memory",
        "pulseaudio",
        "network",
        "bluetooth",
        "battery",
        "custom/power"
    ],
    "custom/power": {
        "format": "βèΜ",
        "tooltip": false,
        "on-click": "wlogout -b 2 -c 0 -r 0 -m 0 --protocol layer-shell"
    },
    "niri/workspaces": {
        "format": "{index}",
        "on-click": "activate"
    },
    "niri/window": {
        "max-length": 40,
        "format": "{title}",
        "separate-outputs": true,
        "rewrite": {
            "": ""
        }
    },
    "clock": {
        "format": "οÄ½  {:%H:%M}",
        "format-alt": "ο¹≥  {:%A, %B %d, %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "format": {
                "today": "<span color='#89b4fa'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },
    "cpu": {
        "format": "ο΄¦  {usage}%",
        "tooltip": false,
        "on-click": "bash -c 'pgrep -x btop >/dev/null && niri msg action focus-window --match app-id=btop || kitty --class btop -e btop'"
    },
    "memory": {
        "format": "οÉâ  {}%",
        "tooltip": "Memory Usage"
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "σΑùü  muted",
        "format-icons": {
            "default": [
                "σΑïΩ",
                "σΑ•Ä",
                "σΑïΨ"
            ]
        },
        "on-click": "kitty --class pamixer sh -c 'pamixer; echo \"\"; echo \"Press Enter to exit.\"; read'",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 5
    },
    "network": {
        "format-wifi": "σΑΛ®  {essid}",
        "format-ethernet": "σΑàÄ  {ifname}",
        "format-disconnected": "σΑΛ≠  offline",
        "tooltip-format": "{ifname} via {gwaddr}",
        "on-click": "bash -c 'pgrep -x impala >/dev/null && niri msg action focus-window --match app-id=impala || kitty --class impala -e impala'"
    },
    "bluetooth": {
        "format": "σΑ²·",
        "format-connected": "σΑ²±  {device_alias}",
        "format-off": "σΑ²≤",
        "on-click": "bash -c 'pgrep -x bluetui >/dev/null && niri msg action focus-window --match app-id=bluetui || kitty --class bluetui -e bluetui'",
        "tooltip-format": "{controller_alias}\n{num_connections} connected"
    },
    "battery": {
        "states": {
            "good": 80,
            "warning": 25,
            "critical": 10
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "σΑ²³  {capacity}%",
        "format-plugged": "σΑöΞ  {capacity}%",
        "format-full": "σΑ¹Ι  full",
        "format-icons": [
            "σΑ¹Κ",
            "σΑ¹Μ",
            "σΑ¹Φ",
            "σΑ¹Ϋ",
            "σΑ¹Ψ",
            "σΑ¹Ω",
            "σΑ²Ä",
            "σΑ²¹",
            "σΑ²²",
            "σΑ¹Ι"
        ]
    },
    "tray": {
        "icon-size": 18,
        "spacing": 8
    },
    "custom/swaync": {
        "tooltip": false,
        "format": "σΑ²ö ",
        "format-alt": "σΑ²ö",
        "exec": "swaync-client -swb",
        "return-type": "json",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    }
}